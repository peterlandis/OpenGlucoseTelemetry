{
  "name": "@openglucose/telemetry-mvp",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "pipeline": "node dist/dev/run-pipeline.js",
    "pipeline:dev": "tsx dev/run-pipeline.ts",
    "typecheck": "tsc --noEmit",
    "verify": "pnpm build && pnpm test && node dist/dev/run-pipeline.js ../../examples/ingestion/healthkit-sample.json && node dist/dev/run-pipeline.js ../../examples/ingestion/dexcom-sample.json",
    "parity:check": "node dev/parity-check.mjs"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "vitest": "^3.0.9"
  },
  "dependencies": {
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1"
  }
}
