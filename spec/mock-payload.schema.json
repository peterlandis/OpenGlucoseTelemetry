{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openglucose.org/schemas/ogt/mock-payload.v0_1.json",
  "title": "Mock adapter payload (OGT MVP)",
  "type": "object",
  "additionalProperties": false,
  "required": ["subject_id", "value", "unit", "observed_at"],
  "properties": {
    "subject_id": {
      "type": "string",
      "minLength": 1
    },
    "value": {
      "type": "number"
    },
    "unit": {
      "type": "string",
      "enum": ["mg/dL", "mmol/L"]
    },
    "observed_at": {
      "type": "string",
      "minLength": 1,
      "format": "date-time"
    }
  }
}
