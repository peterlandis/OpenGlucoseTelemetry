{
  "name": "openglucose-telemetry",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.15.0+sha512.76e2379760a4328ec4415815bcd6628dee727af3779aaa4c914e3944156c4299921a89f976381ee107d41f12cfa4b66681ca9c718f0668fa0831ed4c6d8ba56c",
  "scripts": {
    "build": "pnpm --filter @openglucose/telemetry-mvp build",
    "test": "pnpm --filter @openglucose/telemetry-mvp test",
    "test:watch": "pnpm --filter @openglucose/telemetry-mvp test:watch",
    "pipeline": "node runtimes/typescript/dist/dev/run-pipeline.js",
    "pipeline:dev": "pnpm --filter @openglucose/telemetry-mvp run pipeline:dev",
    "typecheck": "pnpm --filter @openglucose/telemetry-mvp run typecheck",
    "verify": "pnpm build && pnpm test && node runtimes/typescript/dist/dev/run-pipeline.js examples/ingestion/healthkit-sample.json && node runtimes/typescript/dist/dev/run-pipeline.js examples/ingestion/dexcom-sample.json",
    "parity:check": "node runtimes/typescript/dev/parity-check.mjs"
  }
}
