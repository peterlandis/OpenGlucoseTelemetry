{
  "name": "@openglucose/telemetry-mvp",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "pipeline": "node dist/dev/run-pipeline.js",
    "pipeline:dev": "tsx dev/run-pipeline.ts",
    "typecheck": "tsc --noEmit",
    "verify": "pnpm build && pnpm test && pnpm pipeline examples/ingestion/healthkit-sample.json && pnpm pipeline examples/ingestion/dexcom-sample.json",
    "parity:check": "node dev/parity-check.mjs"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "vitest": "^3.0.9"
  },
  "dependencies": {
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1"
  },
  "packageManager": "pnpm@9.15.0+sha512.76e2379760a4328ec4415815bcd6628dee727af3779aaa4c914e3944156c4299921a89f976381ee107d41f12cfa4b66681ca9c718f0668fa0831ed4c6d8ba56c"
}
